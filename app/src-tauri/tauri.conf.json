{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZTKN PawnIO",
  "version": "0.1.0",
  "identifier": "com.valen.ztkn.pawnio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "ZTKN PawnIO",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "binaries/sensor-sidecar-x86_64-pc-windows-msvc.exe": "sensor-sidecar.exe",
      "installer-deps/PawnIO_setup.exe": "PawnIO_setup.exe",
      "../Assets": "Assets",
      "../Panels": "Panels"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  }
}
